                        )
                    )
                )

                if state ~= 'Fakelag' then
                    items.delay_from = config_system.push(
                        'Builder', hash 'delay_from', menu.new(
                            ui.new_slider, 'AA', 'Anti-aimbot angles', new_key('Delay from', hash 'delay_from'), 1, 8, 1, true, 't', 1, {
                                [1] = 'Off'
                            }
