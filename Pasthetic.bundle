            local HOTKEY_MODE = {
                [0] = 'Always on',
                [1] = 'On hotkey',
                [2] = 'Toggle',
                [3] = 'Off hotkey'
            }

            local function get_hotkey_value(_, mode, key)
                return HOTKEY_MODE[mode], key or 0
            end

            fakelag.enabled = config_system.push(
                'Features', 'fakelag.enabled', menu.new(
                    ui.new_checkbox, 'AA', 'Other', new_key('Enabled', 'fakelag')
